# ============================================================
# THERAPY BIO HUB — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# ---- Supabase ----
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — server-side only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- PostHog Analytics ----
# Get these from: https://app.posthog.com → Project Settings → API Keys
# Leave blank to disable analytics (app works fine without it)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- App ----
# Full URL of your deployment (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# The slug of the therapist's page (used for the root redirect /)
# Must match the slug column in the pages table
NEXT_PUBLIC_DEFAULT_SLUG=ana-silva
